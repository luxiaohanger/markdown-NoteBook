### ====================================================================
### --- 1. 构建产物 (C++/CMake/General) ---
### ====================================================================
[build]/
build*/
out/
bin/
x64/
ARM64/
# 所有的中间对象文件和静态/动态库
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.exe
*.out
*.exp
*.pdb
*.ilk

# CMake 内部文件
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
Makefile
compile_commands.json
_deps/

### ====================================================================
### --- 2. 编辑器与 IDE (VS Code / Cursor / JetBrains) ---
### ====================================================================
.vscode/
.cursor/
*.code-workspace

# 如果你偶尔用 CLion 或 PyCharm
.idea/
*.iws
*.iml

### ====================================================================
### --- 3. 操作系统与临时文件 ---
### ====================================================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# 临时与日志文件
*.log
*.tmp
*.temp
*.swp
*~
.nfs*

### ====================================================================
### --- 4. 安全与环境变量 (非常重要！) ---
### ====================================================================
# 永远不要把私钥和 API 密钥传到 Git
*.env
*.env.local
*.env.development.local
*.env.test.local
*.env.production.local
.env*.local
*.pem
*.key
.node_repl_history

### ====================================================================
### --- 5. 语言特定 (OS 实验/全栈相关) ---
### ====================================================================
# Docker (如果你在 Docker 容器里编译 OS 实验)
.dockerignore
# 忽略特定的 Docker 数据卷
.docker-data/

# Python (用于脚本或 AI 流程)
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
venv/
.pytest_cache/

# Node.js (uniblog 可能会用到)
node_modules/
.npm
.eslintcache
.next/

### ====================================================================
### --- 6. 调试器特定 ---
### ====================================================================
*.dSYM/
*.stackdump
*.core
gmon.out